# ==================== MAIL INFRASTRUCTURE ====================
MAILCOW_HOSTNAME=mail.defense-ransomware.local
MAILCOW_ADMIN_USER=admin
MAILCOW_ADMIN_PASS=ChangeMe123!
MAILCOW_TZ=Europe/Paris

# ==================== ORCHESTRATOR ====================
ORCHESTRATOR_PORT=8000
ORCHESTRATOR_SECRET_KEY=your-secret-key-change-me-in-production
DATABASE_URL=postgresql://ransomware_user:SecurePass123@postgres:5432/orchestrator_db
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=90

# ==================== CAPE SANDBOX ====================
CAPE_API_URL=http://cape:8000
CAPE_API_TOKEN=your-cape-api-token
CAPE_DATABASE_CONNECTION=postgresql://cape_user:SecurePass123@postgres:5432/cape_db

# ==================== MISP ====================
MISP_URL=http://misp:80
MISP_API_KEY=your-misp-api-key-change-me
MISP_VERIFY_SSL=false
MISP_ADMIN_EMAIL=admin@defense-ransomware.local
MISP_ADMIN_PASSPHRASE=admin

# ==================== DATABASES ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SecurePostgresPass123
MYSQL_ROOT_PASSWORD=SecureMySQLPass123
MYSQL_DATABASE=misp
MYSQL_USER=misp
MYSQL_PASSWORD=SecurePass123

# ==================== MONITORING ====================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==================== SECURITY ====================
ENCRYPTION_KEY=your-aes256-encryption-key-here
JWT_SECRET=your-jwt-secret-key-here
